  document.getElementById('b-c').style.width=Math.min(totalC/500*100,100)+'%';document.getElementById('b-i').style.width=Math.min(totalI/200*100,100)+'%';document.getElementById('b-a').style.width=Math.min(aqi/200*100,100)+'%';
  document.getElementById('aqi-alert').style.display=aqi>=100?'block':'none';
  if(pc)pc(totalC);if(pa)pa(aqi);if(pgc)pgc(totalC);if(pga)pga(aqi);if(pgi)pgi(totalI);if(pgr)pgr(rate);
  rowN++;const now=new Date(),ts=`${p2(now.getHours())}:${p2(now.getMinutes())}:${p2(now.getSeconds())}`;
  const status=aqi<50?'Normal':aqi<100?'Moderate':'⚠ Alert',sc=aqi<50?'var(--green)':aqi<100?'var(--yellow)':'var(--red)';
  logRows.unshift({n:rowN,ts,c:totalC.toFixed(1),i:totalI.toFixed(2),a:aqi,r:rate.toFixed(1),s:status,sc});
  if(logRows.length>20)logRows.pop();
  const tb=document.getElementById('log-tbody');if(tb)tb.innerHTML=logRows.map(r=>`<tr><td style="color:var(--muted)">#${r.n}</td><td>${r.ts}</td><td style="color:var(--neon)">${r.c}</td><td style="color:var(--neon2)">${r.i}</td><td style="color:${r.sc}">${r.a}</td><td style="color:var(--blue)">${r.r}</td><td style="color:${r.sc}">${r.s}</td></tr>`).join('');
  const bdg=document.getElementById('bdg-log');if(bdg)bdg.textContent=logRows.length;
}
function animNum(id,target,unit){const el=document.getElementById(id);if(!el)return;const cur=parseFloat(el.textContent)||0,steps=20,step=(target-cur)/steps;let i=0;const t=setInterval(()=>{i++;el.innerHTML=(cur+step*i).toFixed(1)+'<small>'+unit+'</small>';if(i>=steps){el.innerHTML=target.toFixed(1)+'<small>'+unit+'</small>';clearInterval(t);}},35);}
function p2(n){return String(n).padStart(2,'0');}

