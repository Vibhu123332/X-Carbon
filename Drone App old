<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>X-CARBON — Turning Pollution Into Ink</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&family=Space+Mono&display=swap" rel="stylesheet">
<style>
:root{
  --p:#7c3aed;--p2:#a855f7;--neon:#c084fc;--neon2:#e879f9;
  --dark:#07020f;--card:rgba(124,58,237,0.08);--border:rgba(168,85,247,0.22);
  --text:#e8dff8;--muted:#9d8fbc;
  --green:#00ff88;--red:#ff3d6b;--yellow:#fbbf24;--blue:#38bdf8;--orange:#fb923c;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--dark);color:var(--text);font-family:'Rajdhani',sans-serif;overflow-x:hidden;min-height:100vh;}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-thumb{background:var(--p);border-radius:2px;}

/* ── SPLASH ── */
#splash{position:fixed;inset:0;background:var(--dark);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .8s ease;}
#splash.hide{opacity:0;pointer-events:none;}
#splash-canvas{position:absolute;inset:0;}
.sp-front{position:relative;z-index:2;text-align:center;display:flex;flex-direction:column;align-items:center;}
.sp-title{font-family:'Orbitron',monospace;font-size:clamp(2.8rem,10vw,7.5rem);font-weight:900;letter-spacing:.15em;background:linear-gradient(135deg,#fff 0%,var(--neon) 40%,var(--neon2) 70%,var(--p) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:glow 1.5s ease-in-out infinite alternate;}
@keyframes glow{from{filter:drop-shadow(0 0 12px rgba(168,85,247,.4));}to{filter:drop-shadow(0 0 50px rgba(192,132,252,.9));}}
.sp-tag{font-family:'Space Mono',monospace;font-size:clamp(.65rem,1.8vw,.9rem);color:var(--muted);letter-spacing:.35em;margin-top:.8rem;text-transform:uppercase;}
.sp-track{width:200px;height:2px;background:rgba(168,85,247,.15);border-radius:2px;margin-top:3rem;overflow:hidden;}
.sp-fill{height:100%;width:0;background:linear-gradient(90deg,var(--p),var(--neon2));border-radius:2px;box-shadow:0 0 8px var(--neon);transition:width .1s linear;}
.sp-st{font-family:'Space Mono',monospace;font-size:.65rem;color:var(--p2);letter-spacing:.12em;margin-top:.7rem;min-height:1.2em;}

/* ── APP ── */
#app{display:none;}
.page{display:none;min-height:100vh;}
.page.active{display:block;animation:fadeIn .35s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:none;}}

/* ── BUTTONS ── */
.btn-main{display:inline-flex;align-items:center;justify-content:center;gap:.6rem;padding:1rem 2.2rem;border-radius:10px;border:none;background:linear-gradient(135deg,var(--p),var(--neon2));color:#fff;font-family:'Rajdhani',sans-serif;font-size:1.05rem;font-weight:700;letter-spacing:.08em;cursor:pointer;transition:all .25s;box-shadow:0 0 24px rgba(124,58,237,.5);}
.btn-main:hover{box-shadow:0 0 45px rgba(168,85,247,.7);transform:translateY(-3px);}
.btn-outline{display:inline-flex;align-items:center;justify-content:center;gap:.6rem;padding:1rem 2.2rem;border-radius:10px;border:1.5px solid var(--border);background:transparent;color:var(--neon);font-family:'Rajdhani',sans-serif;font-size:1.05rem;font-weight:700;letter-spacing:.08em;cursor:pointer;transition:all .25s;}
.btn-outline:hover{border-color:var(--neon);box-shadow:0 0 20px rgba(192,132,252,.2);transform:translateY(-2px);}
.btn-sm{padding:.45rem 1.1rem;border-radius:8px;border:1px solid var(--border);background:rgba(124,58,237,.15);color:var(--neon);font-family:'Space Mono',monospace;font-size:.68rem;cursor:pointer;transition:all .2s;letter-spacing:.06em;}
.btn-sm:hover{background:rgba(124,58,237,.35);box-shadow:0 0 14px rgba(124,58,237,.4);}
.btn-back{display:inline-flex;align-items:center;gap:.5rem;padding:.5rem 1.1rem;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--muted);font-family:'Space Mono',monospace;font-size:.68rem;cursor:pointer;transition:all .2s;}
.btn-back:hover{border-color:var(--neon);color:var(--neon);}

/* ── LANDING ── */
#pg-landing{display:flex;align-items:center;justify-content:center;flex-direction:column;position:relative;overflow:hidden;padding:2rem;min-height:100vh;}
#hero-canvas{position:absolute;inset:0;pointer-events:none;}
.land-inner{position:relative;z-index:2;text-align:center;max-width:720px;}
.land-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.35rem 1.1rem;border:1px solid var(--border);border-radius:50px;font-family:'Space Mono',monospace;font-size:.62rem;color:var(--neon);letter-spacing:.15em;background:rgba(124,58,237,.08);backdrop-filter:blur(10px);margin-bottom:2rem;}
.land-h{font-family:'Orbitron',monospace;font-size:clamp(2rem,6.5vw,5rem);font-weight:900;line-height:1.1;margin-bottom:1.5rem;}
.land-h .g{background:linear-gradient(90deg,var(--neon),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.land-sub{color:var(--muted);font-size:clamp(.9rem,2.5vw,1.1rem);line-height:1.8;max-width:520px;margin:0 auto 2.8rem;}
.btn-row{display:flex;gap:1.2rem;justify-content:center;flex-wrap:wrap;}

/* ── BT PAGE ── */
#pg-bt-inner{max-width:660px;margin:0 auto;padding:0 1.5rem 3rem;}
.pg-lbl{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.35em;color:var(--neon2);text-transform:uppercase;margin-bottom:.5rem;}
.pg-ttl{font-family:'Orbitron',monospace;font-size:clamp(1.3rem,3.5vw,2rem);font-weight:700;color:#fff;margin-bottom:.4rem;}
.pg-sub{color:var(--muted);font-size:.9rem;line-height:1.6;margin-bottom:2rem;}
.bt-box{border:1px solid var(--border);border-radius:16px;background:var(--card);overflow:hidden;}
.bt-top{padding:1.2rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;}
.bt-status{display:flex;align-items:center;gap:.6rem;font-family:'Space Mono',monospace;font-size:.68rem;letter-spacing:.06em;}
.bdot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.bdot.idle{background:var(--muted);}
.bdot.scanning{background:var(--yellow);box-shadow:0 0 8px var(--yellow);animation:blk 1s infinite;}
.bdot.done{background:var(--green);box-shadow:0 0 8px var(--green);}
@keyframes blk{0%,100%{opacity:1;}50%{opacity:.2;}}
.bt-wave{display:flex;align-items:center;justify-content:center;padding:1.8rem;gap:5px;}
.bt-wave span{width:4px;border-radius:2px;background:var(--p2);transition:opacity .3s;}
.bt-wave span:nth-child(1){height:18px;}.bt-wave span:nth-child(2){height:32px;}.bt-wave span:nth-child(3){height:48px;}.bt-wave span:nth-child(4){height:32px;}.bt-wave span:nth-child(5){height:18px;}
.bt-wave.idle span{opacity:.18;}
.bt-wave.active span{animation:wv 1.2s ease-in-out infinite;}
.bt-wave.active span:nth-child(2){animation-delay:.1s;}.bt-wave.active span:nth-child(3){animation-delay:.2s;}.bt-wave.active span:nth-child(4){animation-delay:.3s;}.bt-wave.active span:nth-child(5){animation-delay:.4s;}
@keyframes wv{0%,100%{transform:scaleY(.3);}50%{transform:scaleY(1);}}
.bt-list{padding:0 1.2rem 1.2rem;}
.bt-empty{text-align:center;padding:1.5rem;color:var(--muted);font-family:'Space Mono',monospace;font-size:.72rem;}
.bt-dev{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.9rem 1.1rem;border:1px solid var(--border);border-radius:11px;background:rgba(124,58,237,.04);margin-bottom:.7rem;cursor:pointer;transition:all .25s;animation:slideIn .35s ease both;}
.bt-dev:hover{border-color:var(--p2);background:rgba(124,58,237,.12);transform:translateX(4px);}
@keyframes slideIn{from{opacity:0;transform:translateX(-16px);}to{opacity:1;transform:none;}}
.bt-dev-l{display:flex;align-items:center;gap:.9rem;}
.bt-dev-icon{width:38px;height:38px;border-radius:9px;background:rgba(124,58,237,.15);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;}
.bt-dev-name{font-weight:700;font-size:.92rem;color:#fff;}
.bt-dev-id{font-family:'Space Mono',monospace;font-size:.58rem;color:var(--muted);margin-top:.1rem;}
.bt-dev-r{text-align:right;flex-shrink:0;}
.bt-sig{font-family:'Space Mono',monospace;font-size:.62rem;color:var(--green);margin-bottom:.4rem;}
.bt-conn-btn{padding:.35rem .85rem;border-radius:6px;border:1px solid var(--p2);background:rgba(124,58,237,.18);color:var(--neon);font-family:'Rajdhani',sans-serif;font-size:.82rem;font-weight:700;cursor:pointer;transition:all .2s;}
.bt-conn-btn:hover{background:linear-gradient(135deg,var(--p),var(--neon2));border-color:transparent;color:#fff;}
.bt-conn-btn.connected{background:rgba(0,255,136,.1);border-color:var(--green);color:var(--green);}
.bt-success{display:none;margin:1.2rem;padding:1rem 1.4rem;border-radius:11px;border:1px solid var(--green);background:rgba(0,255,136,.05);color:var(--green);font-family:'Space Mono',monospace;font-size:.74rem;text-align:center;}

/* ── SIDEBAR LAYOUT ── */
#pg-guest{display:flex;min-height:100vh;}
.sidebar{width:232px;flex-shrink:0;background:rgba(10,3,22,.97);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:200;overflow-y:auto;}
.sb-logo{padding:1.4rem 1.4rem 1.2rem;border-bottom:1px solid var(--border);font-family:'Orbitron',monospace;font-weight:900;font-size:1.1rem;letter-spacing:.1em;background:linear-gradient(90deg,var(--neon),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.sb-grp{margin-top:.4rem;}
.sb-grp-lbl{padding:.55rem 1.4rem .2rem;font-family:'Space Mono',monospace;font-size:.56rem;color:rgba(157,143,188,.4);letter-spacing:.2em;text-transform:uppercase;}
.tab-btn{display:flex;align-items:center;gap:.75rem;padding:.7rem 1.4rem;border:none;background:transparent;color:var(--muted);font-family:'Rajdhani',sans-serif;font-size:.95rem;font-weight:600;cursor:pointer;transition:all .18s;width:100%;text-align:left;border-left:2px solid transparent;}
.tab-btn:hover{color:var(--text);background:rgba(124,58,237,.07);}
.tab-btn.active{color:#fff;background:rgba(124,58,237,.14);border-left-color:var(--neon);}
.tab-btn .ti{font-size:1rem;width:20px;text-align:center;flex-shrink:0;}
.tab-badge{margin-left:auto;padding:.1rem .45rem;border-radius:20px;background:rgba(124,58,237,.28);color:var(--neon);font-family:'Space Mono',monospace;font-size:.56rem;}
.tab-btn.active .tab-badge{background:var(--p);color:#fff;}
.tab-badge.new{background:var(--red);color:#fff;animation:blk 1.5s infinite;}
.sb-foot{margin-top:auto;padding:1rem 1.4rem;border-top:1px solid var(--border);display:flex;align-items:center;gap:.5rem;font-family:'Space Mono',monospace;font-size:.62rem;color:var(--green);}
.sb-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);animation:blk 1.2s infinite;}
.content-wrap{margin-left:232px;display:flex;flex-direction:column;min-height:100vh;flex:1;}
.topbar{position:sticky;top:0;z-index:100;padding:.85rem 2rem;background:rgba(7,2,15,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:1rem;}
.tb-title{font-family:'Orbitron',monospace;font-size:.9rem;font-weight:700;color:#fff;}
.tb-sub{color:var(--muted);font-size:.78rem;margin-top:.1rem;}
.tb-right{display:flex;align-items:center;gap:1rem;}
.live-pill{display:flex;align-items:center;gap:.4rem;padding:.3rem .8rem;border-radius:20px;border:1px solid rgba(0,255,136,.2);background:rgba(0,255,136,.06);font-family:'Space Mono',monospace;font-size:.62rem;color:var(--green);}
.ldot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 5px var(--green);animation:blk 1.2s infinite;}
.tab-panel{display:none;padding:2rem;}
.tab-panel.active{display:block;animation:fadeIn .3s ease;}

/* section headers */
.sh-lbl{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.35em;color:var(--neon2);text-transform:uppercase;margin-bottom:.45rem;}
.sh-ttl{font-family:'Orbitron',monospace;font-size:clamp(1.3rem,3vw,2rem);font-weight:700;color:#fff;margin-bottom:.4rem;}
.sh-sub{color:var(--muted);font-size:.88rem;line-height:1.65;max-width:540px;margin-bottom:2rem;}

/* ── DASHBOARD ── */
.d-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1.1rem;margin-bottom:1.5rem;}
.dcard{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.6rem 1.4rem;transition:all .28s;position:relative;overflow:hidden;}
.dcard:hover{transform:translateY(-5px);border-color:var(--p2);box-shadow:0 0 32px rgba(124,58,237,.22);}
.dc-icon{font-size:1.7rem;margin-bottom:.7rem;}
.dc-lbl{font-family:'Space Mono',monospace;font-size:.58rem;letter-spacing:.14em;color:var(--muted);text-transform:uppercase;margin-bottom:.35rem;}
.dc-val{font-family:'Orbitron',monospace;font-size:1.9rem;font-weight:700;color:#fff;line-height:1;}
.dc-val small{font-size:.8rem;color:var(--p2);margin-left:.2rem;}
.dc-trend{font-size:.78rem;color:var(--green);margin-top:.35rem;font-weight:600;}
.dc-bar{height:2px;background:rgba(168,85,247,.15);border-radius:1px;margin-top:.9rem;overflow:hidden;}
.dc-fill{height:100%;background:linear-gradient(90deg,var(--p),var(--neon2));transition:width .7s ease;box-shadow:0 0 5px var(--neon);}
.aqi-alert{display:none;padding:.9rem 1.4rem;border-radius:11px;border:1px solid var(--red);background:rgba(255,61,107,.07);color:var(--red);font-family:'Space Mono',monospace;font-size:.72rem;text-align:center;margin-bottom:1.2rem;animation:ap 1.5s ease-in-out infinite;}
@keyframes ap{0%,100%{box-shadow:0 0 6px rgba(255,61,107,.2);}50%{box-shadow:0 0 22px rgba(255,61,107,.5);}}
.g-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.1rem;margin-top:1rem;}
.gcrd{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:1.3rem;}
.g-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;}
.g-hdr-ttl{font-family:'Orbitron',monospace;font-size:.8rem;font-weight:700;color:#fff;}

/* ── TECH ── */
.tech-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.1rem;}
.tcrd{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:1.6rem 1.4rem;text-align:center;transition:all .28s;cursor:default;}
.tcrd:hover{border-color:var(--p2);box-shadow:0 0 28px rgba(124,58,237,.2);transform:translateY(-4px);}
.tc-icon{font-size:2rem;margin-bottom:.8rem;}
.tc-name{font-family:'Orbitron',monospace;font-size:.82rem;font-weight:700;color:#fff;margin-bottom:.3rem;}
.tc-tag{display:inline-block;padding:.12rem .55rem;border-radius:20px;background:rgba(124,58,237,.2);color:var(--neon);font-family:'Space Mono',monospace;font-size:.56rem;margin-bottom:.5rem;}
.tc-desc{color:var(--muted);font-size:.8rem;line-height:1.55;}

/* ── STEPS ── */
.steps-col{max-width:650px;}
.step-row{display:flex;align-items:flex-start;gap:1.4rem;padding:1.4rem 1.2rem;border-left:2px solid var(--border);margin-left:2.2rem;position:relative;opacity:0;transform:translateX(-18px);transition:opacity .5s ease,transform .5s ease;}
.step-row.vis{opacity:1;transform:none;}
.s-num{position:absolute;left:-1.55rem;top:1.4rem;width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--p),var(--neon2));color:#fff;font-family:'Orbitron',monospace;font-size:.82rem;font-weight:700;display:flex;align-items:center;justify-content:center;box-shadow:0 0 18px rgba(124,58,237,.4);}
.s-body{padding-top:.2rem;}
.s-icon{font-size:1.3rem;margin-bottom:.3rem;}
.s-ttl{font-family:'Orbitron',monospace;font-size:.95rem;font-weight:700;color:#fff;margin-bottom:.3rem;}
.s-desc{color:var(--muted);font-size:.87rem;line-height:1.6;}

/* ── INK ── */
.ink-tl{max-width:650px;}
.ink-row{display:flex;gap:1.4rem;margin-bottom:1.8rem;opacity:0;transform:translateY(16px);transition:opacity .45s ease,transform .45s ease;}
.ink-row.vis{opacity:1;transform:none;}
.ink-l{display:flex;flex-direction:column;align-items:center;flex-shrink:0;}
.ink-ico{width:46px;height:46px;border-radius:11px;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.4rem;}
.ink-line{width:2px;flex:1;min-height:24px;background:linear-gradient(to bottom,var(--p),transparent);margin-top:.4rem;}
.ink-ttl{font-family:'Orbitron',monospace;font-size:.92rem;font-weight:700;color:#fff;margin-bottom:.3rem;}
.ink-desc{color:var(--muted);font-size:.85rem;line-height:1.6;}
.ink-badge{display:inline-flex;gap:.35rem;margin-top:.45rem;padding:.2rem .65rem;border-radius:6px;background:rgba(124,58,237,.14);border:1px solid var(--border);font-family:'Space Mono',monospace;font-size:.62rem;color:var(--neon);}

/* ── IMPACT ── */
.imp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1.1rem;margin-bottom:1.5rem;}
.imp-card{background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.14);border-radius:13px;padding:1.6rem 1.4rem;text-align:center;}
.imp-big{font-family:'Orbitron',monospace;font-size:2.3rem;font-weight:900;color:var(--green);line-height:1;margin-bottom:.35rem;}
.imp-name{font-weight:700;font-size:.92rem;color:#fff;margin-bottom:.25rem;}
.imp-desc{color:var(--muted);font-size:.78rem;line-height:1.5;}

/* ── LOG ── */
.log-wrap{border:1px solid var(--border);border-radius:13px;overflow:hidden;overflow-x:auto;}
.ltbl{width:100%;border-collapse:collapse;font-family:'Space Mono',monospace;font-size:.7rem;}
.ltbl th{background:rgba(124,58,237,.14);color:var(--neon);padding:.75rem 1.1rem;text-align:left;letter-spacing:.1em;font-size:.6rem;text-transform:uppercase;}
.ltbl td{padding:.7rem 1.1rem;border-top:1px solid rgba(168,85,247,.08);color:var(--muted);}
.ltbl tr:hover td{background:rgba(124,58,237,.06);color:var(--text);}

/* ══════════════════════════════════════════════════
   ABOUT ME
══════════════════════════════════════════════════ */
.about-hero{display:flex;gap:2.5rem;align-items:flex-start;flex-wrap:wrap;margin-bottom:2.5rem;}
.about-avatar{
  width:120px;height:120px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,var(--p),var(--neon2));
  display:flex;align-items:center;justify-content:center;
  font-size:3.5rem;
  box-shadow:0 0 0 4px var(--border),0 0 40px rgba(124,58,237,.4);
  animation:avatarPulse 3s ease-in-out infinite;
}
@keyframes avatarPulse{0%,100%{box-shadow:0 0 0 4px var(--border),0 0 30px rgba(124,58,237,.3);}50%{box-shadow:0 0 0 6px rgba(168,85,247,.3),0 0 60px rgba(168,85,247,.5);}}
.about-bio-wrap{flex:1;min-width:260px;}
.about-name{font-family:'Orbitron',monospace;font-size:clamp(1.3rem,3vw,2rem);font-weight:900;color:#fff;margin-bottom:.3rem;}
.about-role{font-family:'Space Mono',monospace;font-size:.72rem;color:var(--neon);letter-spacing:.15em;margin-bottom:1rem;}
.about-bio{color:var(--muted);font-size:.9rem;line-height:1.75;margin-bottom:1.2rem;}
.about-tags{display:flex;flex-wrap:wrap;gap:.5rem;}
.tag{padding:.25rem .7rem;border-radius:20px;border:1px solid var(--border);background:rgba(124,58,237,.1);font-family:'Space Mono',monospace;font-size:.6rem;color:var(--neon2);transition:all .2s;}
.tag:hover{border-color:var(--neon2);background:rgba(232,121,249,.1);}

.about-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1rem;margin-bottom:2rem;}
.astat{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.2rem;text-align:center;transition:all .25s;}
.astat:hover{border-color:var(--p2);transform:translateY(-3px);}
.astat-val{font-family:'Orbitron',monospace;font-size:1.8rem;font-weight:900;color:var(--neon);line-height:1;margin-bottom:.2rem;}
.astat-lbl{font-family:'Space Mono',monospace;font-size:.6rem;color:var(--muted);letter-spacing:.1em;}

.skills-section{margin-bottom:2rem;}
.skill-row{margin-bottom:1rem;}
.skill-label{display:flex;justify-content:space-between;font-family:'Space Mono',monospace;font-size:.68rem;color:var(--text);margin-bottom:.4rem;}
.skill-bar{height:6px;background:rgba(168,85,247,.15);border-radius:3px;overflow:hidden;}
.skill-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--p),var(--neon2));box-shadow:0 0 6px var(--neon);width:0;transition:width 1.2s ease;}

.timeline{max-width:600px;}
.tl-item{display:flex;gap:1.2rem;padding-bottom:1.8rem;position:relative;}
.tl-item::before{content:'';position:absolute;left:16px;top:36px;bottom:0;width:2px;background:linear-gradient(to bottom,var(--p),transparent);}
.tl-dot{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--p),var(--neon2));display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;box-shadow:0 0 12px rgba(124,58,237,.4);}
.tl-body{}
.tl-date{font-family:'Space Mono',monospace;font-size:.6rem;color:var(--neon);letter-spacing:.1em;margin-bottom:.2rem;}
.tl-ttl{font-weight:700;font-size:.95rem;color:#fff;margin-bottom:.2rem;}
.tl-desc{color:var(--muted);font-size:.82rem;line-height:1.55;}

/* ══════════════════════════════════════════════════
   GAMES ZONE
══════════════════════════════════════════════════ */
.games-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.2rem;margin-bottom:2rem;}
.game-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.6rem;text-align:center;transition:all .28s;cursor:pointer;}
.game-card:hover{border-color:var(--neon);box-shadow:0 0 30px rgba(124,58,237,.25);transform:translateY(-4px);}
.game-icon{font-size:2.8rem;margin-bottom:.8rem;}
.game-name{font-family:'Orbitron',monospace;font-size:1rem;font-weight:700;color:#fff;margin-bottom:.3rem;}
.game-desc{color:var(--muted);font-size:.8rem;line-height:1.5;margin-bottom:1rem;}
.game-launch{display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1.2rem;border-radius:8px;background:linear-gradient(135deg,var(--p),var(--neon2));color:#fff;font-family:'Rajdhani',sans-serif;font-size:.9rem;font-weight:700;border:none;cursor:pointer;transition:all .2s;}
.game-launch:hover{box-shadow:0 0 20px rgba(124,58,237,.5);}

/* GAME MODAL */
.gmodal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:5000;align-items:center;justify-content:center;padding:1rem;}
.gmodal.open{display:flex;}
.gmodal-box{background:#0d0520;border:1px solid var(--border);border-radius:18px;padding:1.8rem;max-width:520px;width:100%;max-height:90vh;overflow-y:auto;position:relative;}
.gmodal-close{position:absolute;top:1rem;right:1rem;background:rgba(124,58,237,.2);border:1px solid var(--border);border-radius:8px;color:var(--muted);font-size:.8rem;cursor:pointer;padding:.3rem .7rem;font-family:'Space Mono',monospace;}
.gmodal-close:hover{color:var(--red);border-color:var(--red);}
.gmodal-title{font-family:'Orbitron',monospace;font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:1.5rem;display:flex;align-items:center;gap:.7rem;}

/* SNAKE */
#snake-canvas{border:1px solid var(--border);border-radius:10px;display:block;margin:0 auto;}
.snake-hud{display:flex;justify-content:space-between;align-items:center;margin-bottom:.8rem;}
.snake-score{font-family:'Orbitron',monospace;font-size:1.2rem;font-weight:700;color:var(--neon);}
.snake-controls{display:grid;grid-template-columns:repeat(3,40px);gap:4px;margin:1rem auto 0;width:fit-content;}
.sc-btn{width:40px;height:40px;border-radius:8px;border:1px solid var(--border);background:rgba(124,58,237,.15);color:var(--text);font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;}
.sc-btn:hover,.sc-btn:active{background:rgba(124,58,237,.4);border-color:var(--neon);}
.sc-blank{width:40px;height:40px;}

/* MEMORY */
.memory-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.6rem;margin:0 auto;max-width:340px;}
.mem-card{aspect-ratio:1;border-radius:10px;border:1px solid var(--border);background:rgba(124,58,237,.15);display:flex;align-items:center;justify-content:center;font-size:1.6rem;cursor:pointer;transition:all .3s;user-select:none;}
.mem-card.flipped{background:rgba(124,58,237,.35);border-color:var(--neon);}
.mem-card.matched{background:rgba(0,255,136,.1);border-color:var(--green);animation:matchPop .4s ease;}
.mem-card.hidden-face{font-size:0;}
@keyframes matchPop{0%{transform:scale(1);}50%{transform:scale(1.15);}100%{transform:scale(1);}}
.mem-hud{display:flex;justify-content:space-between;margin-bottom:1rem;font-family:'Space Mono',monospace;font-size:.72rem;color:var(--muted);}
.mem-hud span{color:var(--neon);}

/* QUIZ */
.quiz-q{font-family:'Orbitron',monospace;font-size:.95rem;font-weight:700;color:#fff;margin-bottom:1.5rem;line-height:1.5;}
.quiz-opts{display:flex;flex-direction:column;gap:.7rem;}
.quiz-opt{padding:.85rem 1.2rem;border-radius:10px;border:1px solid var(--border);background:rgba(124,58,237,.08);color:var(--text);font-family:'Rajdhani',sans-serif;font-size:.95rem;font-weight:600;cursor:pointer;transition:all .2s;text-align:left;}
.quiz-opt:hover{border-color:var(--p2);background:rgba(124,58,237,.18);}
.quiz-opt.correct{border-color:var(--green);background:rgba(0,255,136,.1);color:var(--green);}
.quiz-opt.wrong{border-color:var(--red);background:rgba(255,61,107,.08);color:var(--red);}
.quiz-feedback{margin-top:1rem;padding:.8rem 1rem;border-radius:8px;font-family:'Space Mono',monospace;font-size:.72rem;display:none;}
.quiz-feedback.good{display:block;color:var(--green);border:1px solid rgba(0,255,136,.2);background:rgba(0,255,136,.05);}
.quiz-feedback.bad{display:block;color:var(--red);border:1px solid rgba(255,61,107,.2);background:rgba(255,61,107,.05);}
.quiz-progress{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;font-family:'Space Mono',monospace;font-size:.65rem;color:var(--muted);}
.quiz-bar{height:3px;background:rgba(168,85,247,.15);border-radius:2px;margin-bottom:1.5rem;overflow:hidden;}
.quiz-bar-fill{height:100%;background:linear-gradient(90deg,var(--p),var(--neon2));border-radius:2px;transition:width .5s ease;}
.quiz-score-big{text-align:center;padding:2rem;}
.quiz-score-big .num{font-family:'Orbitron',monospace;font-size:4rem;font-weight:900;color:var(--neon);}
.quiz-score-big p{color:var(--muted);margin-top:.5rem;font-size:.9rem;}

/* ══════════════════════════════════════════════════
   FUN EXTRAS / SIDEBAR
══════════════════════════════════════════════════ */
.extras-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.2rem;}
.extra-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.6rem;}
.extra-title{font-family:'Orbitron',monospace;font-size:.88rem;font-weight:700;color:#fff;margin-bottom:.3rem;display:flex;align-items:center;gap:.5rem;}
.extra-sub{color:var(--muted);font-size:.78rem;line-height:1.5;margin-bottom:1rem;}

/* Pollution Fact */
.fact-box{padding:1rem;border-radius:10px;border:1px solid rgba(251,191,36,.2);background:rgba(251,191,36,.05);color:var(--yellow);font-family:'Space Mono',monospace;font-size:.7rem;line-height:1.7;min-height:60px;}
.fact-refresh{margin-top:.7rem;padding:.4rem .9rem;border-radius:7px;border:1px solid rgba(251,191,36,.3);background:transparent;color:var(--yellow);font-family:'Space Mono',monospace;font-size:.62rem;cursor:pointer;transition:all .2s;}
.fact-refresh:hover{background:rgba(251,191,36,.1);}

/* Carbon Calculator */
.calc-input-row{display:flex;gap:.6rem;align-items:center;margin-bottom:.8rem;flex-wrap:wrap;}
.calc-input-row label{font-family:'Space Mono',monospace;font-size:.64rem;color:var(--muted);min-width:90px;}
.calc-inp{flex:1;padding:.45rem .8rem;border-radius:7px;border:1px solid var(--border);background:rgba(124,58,237,.08);color:var(--text);font-family:'Space Mono',monospace;font-size:.75rem;min-width:80px;}
.calc-inp:focus{outline:none;border-color:var(--p2);}
.calc-result{padding:.8rem 1rem;border-radius:9px;background:rgba(124,58,237,.12);border:1px solid var(--border);font-family:'Space Mono',monospace;font-size:.72rem;color:var(--neon);line-height:1.7;}

/* Mood Picker */
.mood-row{display:flex;gap:.6rem;justify-content:center;flex-wrap:wrap;margin-bottom:.8rem;}
.mood-btn{width:44px;height:44px;border-radius:50%;border:1px solid var(--border);background:rgba(124,58,237,.1);font-size:1.4rem;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;}
.mood-btn:hover,.mood-btn.active{border-color:var(--neon);box-shadow:0 0 14px rgba(192,132,252,.3);transform:scale(1.15);}
.mood-msg{font-family:'Space Mono',monospace;font-size:.7rem;color:var(--neon2);text-align:center;min-height:1.4em;}

/* Poll */
.poll-opt{display:flex;align-items:center;gap:.7rem;margin-bottom:.7rem;cursor:pointer;}
.poll-label{font-size:.85rem;color:var(--text);min-width:120px;}
.poll-bar-wrap{flex:1;height:8px;background:rgba(168,85,247,.15);border-radius:4px;overflow:hidden;}
.poll-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--p),var(--neon2));transition:width .8s ease;}
.poll-pct{font-family:'Space Mono',monospace;font-size:.62rem;color:var(--muted);min-width:32px;text-align:right;}
.poll-vote{padding:.5rem 1rem;border-radius:8px;border:1px solid var(--border);background:rgba(124,58,237,.12);color:var(--neon);font-family:'Space Mono',monospace;font-size:.65rem;cursor:pointer;width:100%;margin-top:.5rem;transition:all .2s;}
.poll-vote:hover{background:rgba(124,58,237,.3);}

/* Weather Widget */
.weather-box{display:flex;align-items:center;gap:1rem;}
.weather-icon{font-size:3rem;}
.weather-info{}
.weather-temp{font-family:'Orbitron',monospace;font-size:2rem;font-weight:700;color:#fff;}
.weather-city{font-family:'Space Mono',monospace;font-size:.62rem;color:var(--muted);}
.weather-desc{font-size:.82rem;color:var(--neon);margin-top:.2rem;}

/* Leaderboard */
.lb-row{display:flex;align-items:center;gap:.8rem;padding:.7rem .8rem;border-radius:9px;margin-bottom:.4rem;border:1px solid transparent;transition:all .2s;}
.lb-row:hover{border-color:var(--border);background:rgba(124,58,237,.06);}
.lb-rank{font-family:'Orbitron',monospace;font-size:.9rem;font-weight:700;width:28px;text-align:center;flex-shrink:0;}
.lb-rank.gold{color:var(--yellow);}
.lb-rank.silver{color:#cbd5e1;}
.lb-rank.bronze{color:var(--orange);}
.lb-avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--p),var(--neon2));display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;}
.lb-name{flex:1;font-weight:600;font-size:.88rem;color:#fff;}
.lb-score{font-family:'Space Mono',monospace;font-size:.7rem;color:var(--green);}

/* Responsive */
@media(max-width:700px){
  .sidebar{position:fixed;transform:translateX(-100%);transition:transform .3s ease;z-index:300;}
  .sidebar.mob-open{transform:none;}
  .content-wrap{margin-left:0;}
  .topbar{padding:.85rem 1rem;}
  .tab-panel{padding:1.2rem;}
  .mob-menu-btn{display:flex!important;}
  .memory-grid{grid-template-columns:repeat(4,1fr);}
}
.mob-menu-btn{display:none;flex-direction:column;gap:4px;background:transparent;border:none;cursor:pointer;padding:.3rem;}
.mob-menu-btn span{width:20px;height:2px;background:var(--muted);border-radius:1px;}

/* Confetti */
.confetti-piece{position:fixed;width:8px;height:8px;border-radius:2px;pointer-events:none;z-index:9000;animation:confettiFall linear forwards;}
@keyframes confettiFall{to{transform:translateY(100vh) rotate(720deg);opacity:0;}}

/* Easter egg button */
.egg-btn{position:fixed;bottom:1.2rem;right:1.2rem;width:42px;height:42px;border-radius:50%;background:rgba(124,58,237,.2);border:1px solid var(--border);color:var(--neon);font-size:1.2rem;cursor:pointer;z-index:500;transition:all .25s;display:flex;align-items:center;justify-content:center;}
.egg-btn:hover{background:rgba(124,58,237,.4);box-shadow:0 0 20px rgba(124,58,237,.5);transform:rotate(15deg) scale(1.1);}

/* ── CHATBOT ── */
#xc-chat-btn{position:fixed;bottom:2rem;right:5rem;z-index:9000;width:58px;height:58px;border-radius:50%;background:linear-gradient(135deg,var(--p),var(--neon2));border:none;cursor:pointer;box-shadow:0 0 28px rgba(124,58,237,.65);display:none;align-items:center;justify-content:center;font-size:1.5rem;transition:all .25s;}
#xc-chat-btn:hover{transform:scale(1.12);box-shadow:0 0 48px rgba(168,85,247,.85);}
#xc-chat-btn .cnotif{position:absolute;top:-2px;right:-2px;width:15px;height:15px;border-radius:50%;background:var(--red);border:2px solid var(--dark);animation:blk 1.5s infinite;}
#xc-chat-win{position:fixed;bottom:6.5rem;right:5rem;z-index:9000;width:360px;max-width:calc(100vw - 2rem);height:540px;max-height:calc(100vh - 9rem);background:rgba(7,2,15,.97);border:1px solid var(--border);border-radius:20px;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 0 60px rgba(124,58,237,.35);transform:scale(.92) translateY(12px);opacity:0;pointer-events:none;transition:all .28s cubic-bezier(.34,1.56,.64,1);}
#xc-chat-win.open{transform:none;opacity:1;pointer-events:all;}
.chat-hdr{padding:.9rem 1.2rem;background:linear-gradient(135deg,rgba(124,58,237,.35),rgba(232,121,249,.12));border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.75rem;flex-shrink:0;}
.chat-hdr-av{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--p),var(--neon2));display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;box-shadow:0 0 12px rgba(124,58,237,.5);}
.chat-hdr-info{flex:1;}
.chat-hdr-name{font-family:'Orbitron',monospace;font-size:.78rem;font-weight:700;color:#fff;}
.chat-hdr-status{font-family:'Space Mono',monospace;font-size:.56rem;color:var(--green);display:flex;align-items:center;gap:.3rem;margin-top:.15rem;}
.chat-hdr-close{background:none;border:none;color:var(--muted);font-size:1.1rem;cursor:pointer;padding:.2rem;transition:color .2s;line-height:1;}
.chat-hdr-close:hover{color:var(--neon);}
.chat-msgs{flex:1;overflow-y:auto;padding:.9rem;display:flex;flex-direction:column;gap:.65rem;scroll-behavior:smooth;}
.chat-msgs::-webkit-scrollbar{width:3px;}
.chat-msgs::-webkit-scrollbar-thumb{background:var(--p);border-radius:2px;}
.cmsg{max-width:88%;animation:msgIn .22s ease;}
@keyframes msgIn{from{opacity:0;transform:translateY(7px);}to{opacity:1;transform:none;}}
.cmsg.bot{align-self:flex-start;}
.cmsg.user{align-self:flex-end;}
.cmsg-bubble{padding:.65rem .9rem;border-radius:14px;font-size:.84rem;line-height:1.6;}
.cmsg.bot .cmsg-bubble{background:rgba(124,58,237,.18);border:1px solid rgba(124,58,237,.28);color:var(--text);border-bottom-left-radius:4px;}
.cmsg.user .cmsg-bubble{background:linear-gradient(135deg,var(--p),rgba(168,85,247,.75));color:#fff;border-bottom-right-radius:4px;}
.cmsg-time{font-family:'Space Mono',monospace;font-size:.52rem;color:var(--muted);margin-top:.2rem;padding:0 .15rem;}
.cmsg.user .cmsg-time{text-align:right;}
.chat-typing{display:none;align-items:center;gap:.3rem;padding:.45rem .7rem;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.2);border-radius:12px;border-bottom-left-radius:4px;width:fit-content;}
.chat-typing.show{display:flex;}
.tdot{width:6px;height:6px;border-radius:50%;background:var(--p2);animation:tdot 1.2s ease-in-out infinite;}
.tdot:nth-child(2){animation-delay:.2s;}.tdot:nth-child(3){animation-delay:.4s;}
@keyframes tdot{0%,80%,100%{transform:scale(.65);opacity:.4;}40%{transform:scale(1.1);opacity:1;}}
.chat-quick{padding:.5rem .75rem;display:flex;gap:.35rem;flex-wrap:wrap;border-top:1px solid var(--border);flex-shrink:0;}
.qchip{padding:.28rem .65rem;border-radius:20px;border:1px solid var(--border);background:rgba(124,58,237,.1);color:var(--neon);font-family:'Space Mono',monospace;font-size:.55rem;cursor:pointer;transition:all .18s;white-space:nowrap;}
.qchip:hover{background:rgba(124,58,237,.28);border-color:var(--p2);}
.chat-inp-row{padding:.65rem .9rem;border-top:1px solid var(--border);display:flex;gap:.55rem;align-items:flex-end;flex-shrink:0;}
#chat-input{flex:1;background:rgba(124,58,237,.08);border:1px solid var(--border);border-radius:10px;padding:.5rem .8rem;color:var(--text);font-family:'Rajdhani',sans-serif;font-size:.88rem;resize:none;outline:none;min-height:36px;max-height:80px;transition:border-color .2s;line-height:1.4;}
#chat-input:focus{border-color:var(--p2);}
#chat-input::placeholder{color:var(--muted);}
#chat-send{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,var(--p),var(--neon2));border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0;transition:all .2s;}
#chat-send:hover{box-shadow:0 0 16px rgba(124,58,237,.6);}
#chat-send:disabled{opacity:.5;cursor:not-allowed;}
</style>
</head>
<body>

<!-- SPLASH -->
<div id="splash">
  <canvas id="splash-canvas"></canvas>
  <div class="sp-front">
    <div class="sp-title">X-CARBON</div>
    <div class="sp-tag">Turning Pollution Into Ink</div>
    <div class="sp-track"><div class="sp-fill" id="sp-fill"></div></div>
    <div class="sp-st" id="sp-st">INITIALIZING SYSTEM...</div>
  </div>
</div>

<!-- EASTER EGG BUTTON (visible after splash) -->
<button class="egg-btn" id="egg-btn" style="display:none" onclick="easterEgg()" title="🎉">🥚</button>

<!-- CHATBOT -->
<button id="xc-chat-btn" title="Chat with X-BOT" onclick="toggleChat()">
  🤖
  <div class="cnotif" id="chat-notif"></div>
</button>
<div id="xc-chat-win">
  <div class="chat-hdr">
    <div class="chat-hdr-av">🤖</div>
    <div class="chat-hdr-info">
      <div class="chat-hdr-name">X-BOT</div>
      <div class="chat-hdr-status"><div class="ldot"></div>Online · X-CARBON Assistant</div>
    </div>
    <button class="chat-hdr-close" onclick="toggleChat()">✕</button>
  </div>
  <div class="chat-msgs" id="chat-msgs">
    <div class="chat-typing" id="chat-typing"><div class="tdot"></div><div class="tdot"></div><div class="tdot"></div></div>
  </div>
  <div class="chat-quick" id="chat-quick">
    <button class="qchip" onclick="quickAsk('What is X-CARBON?')">What is X-CARBON?</button>
    <button class="qchip" onclick="quickAsk('How does it capture carbon?')">How it works?</button>
    <button class="qchip" onclick="quickAsk('What ink does it make?')">About the ink</button>
    <button class="qchip" onclick="quickAsk('What sensors are used?')">Tech & sensors</button>
    <button class="qchip" onclick="quickAsk('What is the environmental impact?')">Impact</button>
  </div>
  <div class="chat-inp-row">
    <textarea id="chat-input" placeholder="Ask me anything about X-CARBON…" rows="1" onkeydown="chatKey(event)"></textarea>
    <button id="chat-send" onclick="sendChat()">➤</button>
  </div>
</div>

<!-- GAME MODALS -->
<div class="gmodal" id="modal-snake">
  <div class="gmodal-box" style="max-width:420px;">
    <button class="gmodal-close" onclick="closeModal('modal-snake')">✕ Close</button>
    <div class="gmodal-title">🐍 Carbon Snake</div>
    <div class="snake-hud">
      <div>Score: <span class="snake-score" id="snake-score">0</span></div>
      <button class="btn-sm" onclick="startSnake()" id="snake-start-btn">▶ Start</button>
    </div>
    <canvas id="snake-canvas" width="360" height="300"></canvas>
    <div class="snake-controls">
      <div class="sc-blank"></div>
      <button class="sc-btn" onclick="snakeDir(0,-1)">▲</button>
      <div class="sc-blank"></div>
      <button class="sc-btn" onclick="snakeDir(-1,0)">◀</button>
      <button class="sc-btn" onclick="snakeDir(0,1)">▼</button>
      <button class="sc-btn" onclick="snakeDir(1,0)">▶</button>
    </div>
    <p style="text-align:center;font-family:'Space Mono',monospace;font-size:.65rem;color:var(--muted);margin-top:.8rem;">Use arrow keys or buttons · Eat carbon particles!</p>
  </div>
</div>

<div class="gmodal" id="modal-memory">
  <div class="gmodal-box" style="max-width:440px;">
    <button class="gmodal-close" onclick="closeModal('modal-memory')">✕ Close</button>
    <div class="gmodal-title">🧩 Carbon Memory</div>
    <div class="mem-hud">
      <div>Moves: <span id="mem-moves">0</span></div>
      <div>Pairs: <span id="mem-pairs">0</span>/8</div>
      <div id="mem-time">Time: 0s</div>
    </div>
    <div class="memory-grid" id="memory-grid"></div>
    <div style="text-align:center;margin-top:1rem;">
      <button class="btn-sm" onclick="initMemory()">🔄 New Game</button>
    </div>
  </div>
</div>

<div class="gmodal" id="modal-quiz">
