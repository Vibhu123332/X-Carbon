/* ── CHART ENGINE ── */
function makeChart(id,lineColor,gradColor,maxPts){
  const cv=document.getElementById(id);if(!cv)return()=>{};
  const ctx=cv.getContext('2d');const MAX=maxPts||25;let data=[];
  (function draw(){
    requestAnimationFrame(draw);
    const W=cv.width=cv.offsetWidth,H=cv.height=parseInt(cv.getAttribute('height'))||160;
    ctx.clearRect(0,0,W,H);if(data.length<2)return;
    const PAD={t:16,r:14,b:26,l:42},gW=W-PAD.l-PAD.r,gH=H-PAD.t-PAD.b;
    const mn=Math.min(...data)*.9,mx=Math.max(...data)*1.08||1;
    ctx.strokeStyle='rgba(168,85,247,.1)';ctx.lineWidth=1;
    for(let i=0;i<=3;i++){const y=PAD.t+gH*(i/3);ctx.beginPath();ctx.moveTo(PAD.l,y);ctx.lineTo(W-PAD.r,y);ctx.stroke();ctx.fillStyle='rgba(157,143,188,.55)';ctx.font='9px Space Mono,monospace';ctx.textAlign='right';ctx.fillText((mx-(mx-mn)*(i/3)).toFixed(1),PAD.l-4,y+3.5);}
    function xp(i){return PAD.l+gW*(i/(MAX-1));}function yp(v){return PAD.t+gH*(1-(v-mn)/(mx-mn));}
    const grad=ctx.createLinearGradient(0,PAD.t,0,PAD.t+gH);grad.addColorStop(0,gradColor+'35');grad.addColorStop(1,gradColor+'00');
    ctx.beginPath();data.forEach((v,i)=>i===0?ctx.moveTo(xp(i),yp(v)):ctx.lineTo(xp(i),yp(v)));ctx.lineTo(xp(data.length-1),PAD.t+gH);ctx.lineTo(xp(0),PAD.t+gH);ctx.closePath();ctx.fillStyle=grad;ctx.fill();
    ctx.beginPath();ctx.strokeStyle=lineColor;ctx.lineWidth=2;ctx.shadowColor=lineColor;ctx.shadowBlur=6;data.forEach((v,i)=>i===0?ctx.moveTo(xp(i),yp(v)):ctx.lineTo(xp(i),yp(v)));ctx.stroke();ctx.shadowBlur=0;
    const lx=xp(data.length-1),ly=yp(data[data.length-1]);ctx.beginPath();ctx.arc(lx,ly,4,0,Math.PI*2);ctx.fillStyle=lineColor;ctx.shadowColor=lineColor;ctx.shadowBlur=12;ctx.fill();ctx.shadowBlur=0;
  })();
  return v=>{data.push(v);if(data.length>MAX)data.shift();};
}

/* ── DEMO DATA ── */
let totalC=0,totalI=0,logRows=[],rowN=0,demoStarted=false;
