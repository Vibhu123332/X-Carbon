/* ════════════════════════════════════════════════
   🐍 SNAKE GAME
════════════════════════════════════════════════ */
let snakeInterval,snake,food,dir,nextDir,snakeScore=0,snakeRunning=false,snakeBest=0;
const COLS=18,ROWS=15,SZ=20;
function startSnake(){
  snake=[{x:9,y:7},{x:8,y:7},{x:7,y:7}];dir={x:1,y:0};nextDir={x:1,y:0};snakeScore=0;snakeRunning=true;
  placeFood();clearInterval(snakeInterval);snakeInterval=setInterval(snakeStep,130);
  document.getElementById('snake-score').textContent=0;
  document.addEventListener('keydown',snakeKey);
}
function snakeKey(e){const map={ArrowUp:{x:0,y:-1},ArrowDown:{x:0,y:1},ArrowLeft:{x:-1,y:0},ArrowRight:{x:1,y:0}};if(map[e.key]){e.preventDefault();const d=map[e.key];if(d.x!==-dir.x||d.y!==-dir.y)nextDir=d;}}
function snakeDir(dx,dy){const d={x:dx,y:dy};if(d.x!==-dir.x||d.y!==-dir.y)nextDir=d;}
function placeFood(){food={x:Math.floor(Math.random()*COLS),y:Math.floor(Math.random()*ROWS)};}
function snakeStep(){
  dir=nextDir;
  const head={x:snake[0].x+dir.x,y:snake[0].y+dir.y};
  if(head.x<0||head.x>=COLS||head.y<0||head.y>=ROWS||snake.some(s=>s.x===head.x&&s.y===head.y)){
    clearInterval(snakeInterval);snakeRunning=false;document.removeEventListener('keydown',snakeKey);
    if(snakeScore>snakeBest){snakeBest=snakeScore;document.getElementById('hs-snake').textContent=`Best: ${snakeBest}`;}
    drawSnake(true);return;
  }
  snake.unshift(head);
  if(head.x===food.x&&head.y===food.y){snakeScore+=10;document.getElementById('snake-score').textContent=snakeScore;placeFood();}
  else snake.pop();
  drawSnake(false);
}
function drawSnake(dead){
  const cv=document.getElementById('snake-canvas'),ctx=cv.getContext('2d');
  ctx.fillStyle='#07020f';ctx.fillRect(0,0,cv.width,cv.height);
  // grid
  ctx.strokeStyle='rgba(168,85,247,.06)';ctx.lineWidth=1;
  for(let x=0;x<=COLS;x++){ctx.beginPath();ctx.moveTo(x*SZ,0);ctx.lineTo(x*SZ,ROWS*SZ);ctx.stroke();}
  for(let y=0;y<=ROWS;y++){ctx.beginPath();ctx.moveTo(0,y*SZ);ctx.lineTo(COLS*SZ,y*SZ);ctx.stroke();}
  // food
  ctx.font=`${SZ-2}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText('🌑',food.x*SZ+SZ/2,food.y*SZ+SZ/2);
  // snake
  snake.forEach((s,i)=>{
    ctx.fillStyle=dead?'rgba(255,61,107,.6)':i===0?'#c084fc':'rgba(168,85,247,'+(1-.03*i)+')';
    ctx.shadowColor=dead?'var(--red)':'var(--neon)';ctx.shadowBlur=i===0?12:4;
    ctx.fillRect(s.x*SZ+1,s.y*SZ+1,SZ-2,SZ-2);
  });
  ctx.shadowBlur=0;
